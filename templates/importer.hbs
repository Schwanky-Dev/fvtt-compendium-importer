<div class="ci-container">
  <!-- Search Bar -->
  <div class="ci-search-bar">
    <div class="ci-search-input-group">
      <input type="text" name="query" value="{{searchQuery}}"
             placeholder="{{localize 'COMPIMPORTER.SearchPlaceholder'}}" autofocus />
      <button type="button" data-action="search" class="ci-search-btn">
        <i class="fas fa-search"></i>
      </button>
    </div>
  </div>

  <!-- Results -->
  <div class="ci-results">
    {{#if loading}}
      <div class="ci-status">
        <i class="fas fa-spinner fa-spin fa-2x"></i>
        <p>{{localize "COMPIMPORTER.Loading"}}</p>
      </div>
    {{else if noResults}}
      <div class="ci-status">
        <i class="fas fa-search fa-2x"></i>
        <p>{{localize "COMPIMPORTER.NoResults"}}</p>
      </div>
    {{else if hasResults}}
      <div class="ci-results-list">
        {{#each results}}
          <div class="ci-row">
            <div class="ci-row-info">
              <span class="ci-name">{{this.name}}</span>
              <span class="ci-badge ci-badge-type">{{this.typeBadge}}</span>
              <span class="ci-badge ci-badge-source" style="background:{{this.sourceColor}}">{{this.sourceLabel}}</span>
              {{#if this.metaInfo}}<span class="ci-meta">{{this.metaInfo}}</span>{{/if}}
            </div>
            <button type="button" data-action="importResult" data-index="{{this.index}}"
                    class="ci-import-btn" {{#if this.importing}}disabled{{/if}}>
              {{#if this.importing}}
                <i class="fas fa-spinner fa-spin"></i>
              {{else}}
                <i class="fas fa-download"></i>
              {{/if}}
            </button>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="ci-status ci-welcome">
        <i class="fas fa-dragon fa-3x"></i>
        <p>Search for monsters, spells, and items</p>
        <p class="ci-hint">Try "goblin", "fireball", or "longsword"</p>
      </div>
    {{/if}}
  </div>
</div>

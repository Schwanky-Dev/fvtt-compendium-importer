<div class="ci-container">
  <!-- Search Bar -->
  <div class="ci-search-bar">
    <div class="ci-search-input-group">
      <input type="text" name="query" value="{{searchQuery}}"
             placeholder="{{localize 'COMPIMPORTER.SearchPlaceholder'}}" autofocus />
      <button type="button" data-action="search" class="ci-search-btn">
        <i class="fas fa-search"></i>
      </button>
    </div>
    <div class="ci-search-options">
      <div class="ci-pass-group">
        <button type="button" class="ci-pass-btn {{#if (eq searchPass 'quick')}}active{{/if}}" data-pass="quick" title="Primary source only">Quick</button>
        <button type="button" class="ci-pass-btn {{#if (eq searchPass 'standard')}}active{{/if}}" data-pass="standard" title="Open5e + AideDD + Roll20">Standard</button>
        <button type="button" class="ci-pass-btn {{#if (eq searchPass 'deep')}}active{{/if}}" data-pass="deep" title="All enabled sources">Deep</button>
        <button type="button" class="ci-tier-config-btn" data-action="configureTiers" title="Configure search tiers"><i class="fas fa-cog"></i></button>
      </div>
      <label class="ci-exact-toggle">
        <input type="checkbox" name="exactMatch" {{#if exactMatch}}checked{{/if}} />
        Exact match
      </label>
    </div>
    {{#if hasResults}}
    <div class="ci-filter-bar">
      <input type="text" name="resultFilter" value="{{filterText}}" placeholder="Filter results..." />
    </div>
    {{/if}}
  </div>

  <!-- Results -->
  <div class="ci-results">
    {{#if loading}}
      <div class="ci-status">
        <i class="fas fa-spinner fa-spin fa-2x"></i>
        <p>{{localize "COMPIMPORTER.Loading"}}</p>
      </div>
    {{else if noResults}}
      <div class="ci-status">
        <i class="fas fa-search fa-2x"></i>
        <p>{{localize "COMPIMPORTER.NoResults"}}</p>
      </div>
    {{else if hasResults}}
      <div class="ci-results-list">
        {{#each results}}
          <div class="ci-row" data-action="previewResult" data-index="{{this.index}}">
            <div class="ci-row-info">
              <span class="ci-name">{{this.name}}</span>
              <span class="ci-badge ci-badge-type">{{this.typeBadge}}</span>
              <span class="ci-badge ci-badge-source" style="background:{{this.sourceColor}}">{{this.sourceLabel}}</span>
              {{#if this.bookBadge}}<span class="ci-badge ci-badge-book" style="background:{{this.sourceBadgeColor}}">{{this.bookBadge}}</span>{{/if}}
              {{#if this.metaInfo}}<span class="ci-meta">{{this.metaInfo}}</span>{{/if}}
            </div>
            <button type="button" data-action="importResult" data-index="{{this.index}}"
                    class="ci-import-btn" {{#if this.importing}}disabled{{/if}}>
              {{#if this.importing}}
                <i class="fas fa-spinner fa-spin"></i>
              {{else}}
                <i class="fas fa-download"></i>
              {{/if}}
            </button>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="ci-status ci-welcome">
        <i class="fas fa-dragon fa-3x"></i>
        <p>Search for monsters, spells, and items</p>
        <p class="ci-hint">Try "goblin", "fireball", or "longsword"</p>
      </div>
    {{/if}}
  </div>

  <!-- Preview Panel -->
  {{#if previewHtml}}
    <div class="ci-preview-panel">
      <div class="ci-preview-header">
        <span>Preview</span>
        <button type="button" data-action="closePreview" class="ci-preview-close"><i class="fas fa-times"></i></button>
      </div>
      <div class="ci-preview-content">{{{previewHtml}}}</div>
    </div>
  {{/if}}
</div>
